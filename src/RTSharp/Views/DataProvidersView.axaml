<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="600"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:plugin="clr-namespace:RTSharp.Plugin"
             xmlns:converters="clr-namespace:RTSharp.ViewModels.Converters;assembly=RTSharp"
             xmlns:vm="clr-namespace:RTSharp.ViewModels"
             xmlns:models="clr-namespace:RTSharp.Models"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             x:Class="RTSharp.Views.DataProvidersView"
             x:DataType="vm:DataProvidersViewModel"
             x:CompileBindings="True">

    <Control.Resources>
        <converters:SIDataSpeedConverter x:Key="SIDataSpeedConverter" />
        <converters:ETATimeSpanConverter x:Key="ETATimeSpanConverter" />
    </Control.Resources>
    
    <ListBox ItemsSource="{Binding Items}">
        <ListBox.ItemTemplate>
            <DataTemplate>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{Binding DisplayName}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding State}" />
                        <TextBlock Padding="4 0 0 0" Text="(" />
                        <TextBlock Text="{Binding Latency, Mode=OneWay, Converter={StaticResource ETATimeSpanConverter}}" />
                        <TextBlock Text=")" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <i:Icon Margin="0 0 4 0" Value="fa7-solid fa7-download" />
                        <TextBlock Padding="0 0 8 0" Text="{Binding TotalDLSpeed, Mode=OneWay, Converter={StaticResource SIDataSpeedConverter}}" />

                        <i:Icon Margin="0 0 4 0" Value="fa7-solid fa7-upload" />
                        <TextBlock Text="{Binding TotalUPSpeed, Mode=OneWay, Converter={StaticResource SIDataSpeedConverter}}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ActiveTorrentCount}" />
                        <TextBlock Text=" active torrents" />
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
