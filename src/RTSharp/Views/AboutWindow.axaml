<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:RTSharp.ViewModels"
        xmlns:sc="clr-namespace:RTSharp.Shared.Controls.Views;assembly=RTSharp.Shared.Controls"
	    xmlns:sys="using:System"
        mc:Ignorable="d" d:DesignWidth="780" d:DesignHeight="540"
        Width="840" Height="310"
        MaxWidth="840" MaxHeight="310"
        x:Class="RTSharp.Views.AboutWindow"
        x:DataType="vm:AboutWindowViewModel"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/rtsharp.ico"
        Title="About RT#">

    <Design.DataContext>
        <vm:AboutWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="StackPanel.plane">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        </Style>

        <Style Selector="ListBox.libraries ListBoxItem">
            <Setter Property="Padding" Value="10,6" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="220,*">
        <ListBox Grid.Column="0"
                 Classes="libraries"
                 Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                 ItemsSource="{Binding Libraries}"
                 SelectedItem="{Binding SelectedLibrary}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="sys:String">
                    <TextBlock Text="{Binding .}" TextWrapping="NoWrap" VerticalAlignment="Center" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Column="1" RowDefinitions="310" IsVisible="{Binding RTSharpPage}">
            <Panel Grid.Row="0">
                <Image Source="/Assets/clouds_fg.png" ZIndex="2" RenderOptions.BitmapInterpolationMode="None" />
                <Image Source="/Assets/clouds_bg.png" RenderOptions.BitmapInterpolationMode="None" />

                <Panel ZIndex="2">
                    <TextBlock
                        Text="RT#"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        FontSize="52"
                        FontWeight="Bold"
                        Foreground="White"
                    >
                        <TextBlock.Effect>
                            <DropShadowDirectionEffect ShadowDepth="4" Direction="330" Color="Black" Opacity="0.5" BlurRadius="4" />
                        </TextBlock.Effect>
                        <TextBlock Text="{Binding Version, StringFormat='v{0}'}" HorizontalAlignment="Center" Opacity="0.5" FontSize="12" />
                    </TextBlock>
                </Panel>

                <Canvas x:Name="PlaneCanvas" ClipToBounds="True">
                    <StackPanel x:Name="PlanePanel" Classes="plane" Orientation="Horizontal" Spacing="6"
                                Canvas.Left="-160" Canvas.Top="64">
                        <TextBlock Text="·" Foreground="White" Opacity="0.12" FontSize="22" VerticalAlignment="Center" />
                        <TextBlock Text="·" Foreground="White" Opacity="0.22" FontSize="22" VerticalAlignment="Center" />
                        <TextBlock Text="·" Foreground="White" Opacity="0.38" FontSize="22" VerticalAlignment="Center" />
                        <TextBlock Text="·" Foreground="White" Opacity="0.55" FontSize="22" VerticalAlignment="Center" />
                        <sc:BuiltInIconImage Value="PLANE" />
                    </StackPanel>
                </Canvas>
            </Panel>
        </Grid>

        <DockPanel Grid.Column="1" IsVisible="{Binding !RTSharpPage}">
            <TextBlock DockPanel.Dock="Top"
                       Text="{Binding SelectedLibrary}"
                       Padding="12,12,12,8" FontSize="20" FontWeight="SemiBold" />
            <TextBox Text="{Binding LicenseText}"
                     xml:space="preserve"
                     Margin="6,0,6,6"
                     BorderThickness="0"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     FontFamily="Consolas"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </DockPanel>
    </Grid>
</Window>
