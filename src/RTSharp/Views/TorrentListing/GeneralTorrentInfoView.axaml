<UserControl x:Class="RTSharp.Views.TorrentListing.GeneralTorrentInfoView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:RTSharp.ViewModels.Converters;assembly=RTSharp"
			 xmlns:sharedConverters="using:RTSharp.Shared.Controls.Converters"
             xmlns:models="clr-namespace:RTSharp.Models"
             xmlns:views="using:RTSharp.Shared.Controls.Views"
             xmlns:torrentListing="clr-namespace:RTSharp.ViewModels.TorrentListing"
			 x:DataType="torrentListing:GeneralTorrentInfoViewModel"
             x:Name="Root"
             d:DesignWidth="1500" d:DesignHeight="450">

    <Control.Resources>
        <converters:SIDataSizeConverter x:Key="SIDataSizeConverter" />
        <converters:SIDataSpeedConverter x:Key="SIDataSpeedConverter" />
        <converters:ETATimeSpanConverter x:Key="ETATimeSpanConverter" />
        <sharedConverters:ToHexStringConverter x:Key="ToHexStringConverter" />
    </Control.Resources>
    <Design.DataContext>
        <torrentListing:GeneralTorrentInfoViewModel />
    </Design.DataContext>
    <UserControl.Styles>
        <StyleInclude Source="avares://RTSharp.Shared.Controls/Themes/GroupBox.axaml" />
    </UserControl.Styles>

    <ContentControl Content="{Binding Torrent}">
        <ContentControl.ContentTemplate>
            <DataTemplate x:DataType="models:Torrent">
                <StackPanel Margin="8 16 8 8">
                    <TextBlock FontSize="16" Text="{Binding Name}" Margin="0 0 0 8" />

                    <Grid ColumnDefinitions="*, Auto" Margin="0 0 0 16">
                        <Border Grid.Column="0" BorderBrush="DarkGray" BorderThickness="1">
                            <views:PieceProgressBar Pieces="{Binding #Root.ViewModel.Pieces}" Height="20" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding Done, StringFormat=\{0:0.00\} %}" Padding="8 0 0 0" VerticalAlignment="Center" />
                    </Grid>

                    <views:GroupBox Label="Transfer">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,*,*">
                            <views:TextBlockWithLabel Grid.Row="0" Grid.Column="0" Label="Time elapsed:" Text="{Binding TimeElapsed, Converter={StaticResource ETATimeSpanConverter}}" />
                            <views:TextBlockWithLabel Grid.Row="1" Grid.Column="0" Label="Downloaded:" Text="{Binding DownloadedDisplay}" />
                            <views:TextBlockWithLabel Grid.Row="2" Grid.Column="0" Label="Uploaded:" Text="{Binding UploadedDisplay}" />
                            <views:TextBlockWithLabel Grid.Row="3" Grid.Column="0" Label="Seeders:" Text="{Binding SeedersDisplay}" />

                            <views:TextBlockWithLabel Grid.Row="0" Grid.Column="1" Label="Remaining:" Text="{Binding ETADisplay}" />
                            <views:TextBlockWithLabel Grid.Row="1" Grid.Column="1" Label="DL Speed:" Text="{Binding DLSpeedDisplay}" />
                            <views:TextBlockWithLabel Grid.Row="2" Grid.Column="1" Label="UP Speed:" Text="{Binding UPSpeedDisplay}" />
                            <views:TextBlockWithLabel Grid.Row="3" Grid.Column="1" Label="Peers:" Text="{Binding PeersDisplay}" />

                            <views:TextBlockWithLabel Grid.Row="0" Grid.Column="2" Label="Ratio:" Text="{Binding RatioDisplay}" />
                            <views:TextBlockWithLabel Grid.Row="1" Grid.Column="2" Label="Wasted:" Text="{Binding Wasted, Converter={StaticResource SIDataSizeConverter}}" />
                        </Grid>
                    </views:GroupBox>
                    <views:GroupBox Label="Torrent info">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,*">
                            <views:TextBlockWithLabel Grid.Row="0" Grid.Column="0" Label="Remote path:" Text="{Binding RemotePath}" />
                            <views:TextBlockWithLabel Grid.Row="1" Grid.Column="0" Label="Created on:" Text="{Binding CreatedOnDateDisplay}" />
                            <views:TextBlockWithLabel Grid.Row="2" Grid.Column="0" Label="Added on:" Text="{Binding AddedOnDateDisplay}" />
                            <views:TextBlockWithLabel Grid.Row="3" Grid.Column="0" Label="Info hash:" Text="{Binding Hash, Converter={StaticResource ToHexStringConverter}}">
                                <views:TextBlockWithLabel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="_Copy" Click="CopyHash_Click" />
                                    </ContextMenu>
                                </views:TextBlockWithLabel.ContextMenu>
                            </views:TextBlockWithLabel>
                            <views:TextBlockWithLabel Grid.Row="0" Grid.Column="1" Label="Comment:" Text="{Binding Comment}" />
                            <views:TextBlockWithLabel Grid.Row="1" Grid.Column="1" Label="Status:" Text="{Binding StatusMsg}" />
                        </Grid>
                    </views:GroupBox>
                </StackPanel>
            </DataTemplate>
        </ContentControl.ContentTemplate>
    </ContentControl>
</UserControl>
