<UserControl x:Class="RTSharp.Views.ActionQueuesView"
         xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:vm="clr-namespace:RTSharp.ViewModels;assembly=RTSharp"
         x:DataType="vm:ActionQueuesViewModel"
         d:DesignWidth="800" d:DesignHeight="400">

    <ScrollViewer>
        <ItemsRepeater Name="QueueRepeater" ItemsSource="{Binding QueueRenderers}" />
    </ScrollViewer>
</UserControl>
