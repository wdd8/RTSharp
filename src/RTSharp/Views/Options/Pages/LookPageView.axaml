<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="clr-namespace:RTSharp.ViewModels.Options.Pages"
             xmlns:views="clr-namespace:RTSharp.Shared.Controls.Views;assembly=RTSharp.Shared.Controls"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="300"
             x:Class="RTSharp.Views.Options.Pages.LookPageView"
             x:DataType="pages:LookPageViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0 0 8 0" />
        </Style>
        <Style Selector="TextBlock.unit">
            <Setter Property="Margin" Value="4 0 0 6" />
        </Style>
    </UserControl.Styles>

    <StackPanel Margin="8" Spacing="12">
        <views:GroupBox Label="Data providers">
            <CheckBox IsChecked="{Binding SpeedChartEnabled}">Show speed chart</CheckBox>
        </views:GroupBox>

        <views:GroupBox Label="Torrent listing">
            <Grid ColumnDefinitions="150, Auto, Auto">
                <TextBlock Grid.Column="0">Row height:</TextBlock>
                <NumericUpDown Grid.Column="1" Value="{Binding RowHeight}" Minimum="8" Maximum="64" />
                <TextBlock Grid.Column="2" Classes="unit">px</TextBlock>
            </Grid>
        </views:GroupBox>
    </StackPanel>
</UserControl>
