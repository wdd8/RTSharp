<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="clr-namespace:RTSharp.ViewModels.Options.Pages"
             xmlns:views="clr-namespace:RTSharp.Shared.Controls.Views;assembly=RTSharp.Shared.Controls"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="400"
             x:Class="RTSharp.Views.Options.Pages.CachingPageView"
             x:DataType="pages:CachingPageViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0 0 8 0" />
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Margin" Value="0 0 0 6" />
        </Style>
    </UserControl.Styles>

    <StackPanel Margin="8" Spacing="12">
        <views:GroupBox Label="Files cache">
            <StackPanel Spacing="8">
                <CheckBox IsChecked="{Binding FilesCachingEnabled}">Enable files caching</CheckBox>
                <Grid ColumnDefinitions="200,Auto" RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Column="0" Grid.Row="0">Concurrent peer caching requests:</TextBlock>
                    <NumericUpDown Grid.Column="1" Grid.Row="0"
                                   Value="{Binding ConcurrentPeerCachingRequests}"
                                   Minimum="1"
                                   IsEnabled="{Binding FilesCachingEnabled}" />

                    <TextBlock Grid.Column="0" Grid.Row="1">In-memory images:</TextBlock>
                    <NumericUpDown Grid.Column="1" Grid.Row="1" Value="{Binding InMemoryImages}" Minimum="0" />
                </Grid>
            </StackPanel>
        </views:GroupBox>

        <views:GroupBox Label="Cached data">
            <StackPanel Spacing="6">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                        <TextBlock>AS cache</TextBlock>
                        <Image Source="{Binding FlatQuestionMarkIcon}"
                               Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"
                               ToolTip.Tip="Caches autonomous system (ISP/network) information for IP addresses seen in the peers list." />
                    </StackPanel>
                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ASCacheInfo}" />
                    <Button Grid.Column="2" Margin="8 0 0 0" Command="{Binding ClearASCacheCommand}">Clear</Button>
                </Grid>

                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                        <TextBlock>Torrent file cache</TextBlock>
                        <Image Source="{Binding FlatQuestionMarkIcon}"
                               Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"
                               ToolTip.Tip="Caches the list of files contained in each torrent to avoid re-fetching from the daemon." />
                    </StackPanel>
                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding TorrentFileCacheInfo}" />
                    <Button Grid.Column="2" Margin="8 0 0 0" Command="{Binding ClearTorrentFileCacheCommand}">Clear</Button>
                </Grid>

                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                        <TextBlock>Torrent properties cache</TextBlock>
                        <Image Source="{Binding FlatQuestionMarkIcon}"
                               Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"
                               ToolTip.Tip="Caches basic torrent properties such as whether a torrent contains multiple files." />
                    </StackPanel>
                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding TorrentPropertiesCacheInfo}" />
                    <Button Grid.Column="2" Margin="8 0 0 0" Command="{Binding ClearTorrentPropertiesCacheCommand}">Clear</Button>
                </Grid>

                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                        <TextBlock>Image cache</TextBlock>
                        <Image Source="{Binding FlatQuestionMarkIcon}"
                               Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"
                               ToolTip.Tip="Caches scaled favicons and other images fetched from remote sources." />
                    </StackPanel>
                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ImageCacheInfo}" />
                    <Button Grid.Column="2" Margin="8 0 0 0" Command="{Binding ClearImageCacheCommand}">Clear</Button>
                </Grid>
            </StackPanel>
        </views:GroupBox>
    </StackPanel>
</UserControl>
