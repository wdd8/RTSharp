<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:RTSharp.Shared.Abstractions.Client.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="200"
             x:DataType="vm:DefaultActionQueueViewModel"
             x:Class="RTSharp.Shared.Abstractions.Client.Views.DefaultActionQueueView">
    <Grid Margin="0,0,0,8" ColumnDefinitions="Auto,*">
        <Image Source="{Binding Icon}" Width="32" Height="32"
               Margin="0,0,8,0" VerticalAlignment="Top" IsVisible="{Binding HasIcon}" />
        <StackPanel Grid.Column="1" Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock FontWeight="SemiBold" FontSize="13" Text="{Binding DisplayName}"
                           VerticalAlignment="Center" />
                <Border Background="#3373B7" CornerRadius="10" Padding="6,2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ActionsInQueue}" Foreground="White" FontSize="11" />
                </Border>
                <Border Background="#C0392B" CornerRadius="10" Padding="6,2" VerticalAlignment="Center"
                        IsVisible="{Binding HasErrors}">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="!" Foreground="White" FontSize="11" FontWeight="Bold" />
                        <TextBlock Text="{Binding ErroredActions}" Foreground="White" FontSize="11" />
                    </StackPanel>
                </Border>
            </StackPanel>
            <ItemsRepeater ItemsSource="{Binding Actions}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:DefaultActionQueueActionViewModel">
                        <Border Margin="{Binding IndentMargin}" Padding="0,2">
                            <StackPanel Spacing="3">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                                    <Ellipse Grid.Column="0" Width="7" Height="7" Fill="{Binding StatusBrush}"
                                             VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap" />
                                    <TextBlock Grid.Column="2" Text="{Binding ProgressLabel}" FontSize="11" Opacity="0.6"
                                               VerticalAlignment="Center" IsVisible="{Binding HasProgress}" />
                                </Grid>
                                <ProgressBar Value="{Binding ProgressDone}" Maximum="100" Height="3"
                                             Margin="13,0,0,0"
                                             IsVisible="{Binding HasProgress}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </Grid>
</UserControl>
